# =========================================
# Server
# =========================================
PORT=5000
FRONTEND_URLS=http://localhost:3000,https://your-production-domain.com

# =========================================
# Database
# =========================================
MONGO_URI=mongodb://localhost:27017/luxury-matrimony

# =========================================
# JWT
# =========================================
JWT_SECRET=your_jwt_secret_here

# =========================================
# Admin Default Credentials (auto-seeded on startup)
# =========================================
# Super Admin — full access
SUPER_ADMIN_EMAIL=admin@rvrluxury.com
SUPER_ADMIN_PASSWORD=Admin@123456

# Admin — limited access
ADMIN_EMAIL=admin2@rvrluxury.com
ADMIN_PASSWORD=Admin@123

# =========================================
# Cloudinary
# =========================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# =========================================
# Limits
# =========================================
DAILY_INTEREST_LIMIT=5
GOLD_DAILY_CHAT_LIMIT=5

# =========================================
# Email SMTP (Gmail App Password)
# =========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# =========================================
# Razorpay
# =========================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# =========================================
# Google OAuth
# =========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
