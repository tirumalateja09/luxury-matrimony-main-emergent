{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/matches/layout,_N_T_/admin/matches/page,_N_T_/admin/matches"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/matches/__PAGE__",
    "/admin/matches",
    "/admin",
    "/_index",
    "/_head"
  ]
}